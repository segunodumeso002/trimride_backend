PORT=3001
DB_HOST=localhost
DB_PORT=5432
DB_NAME=barber_app
DB_USER=postgres
DB_PASSWORD=replace_with_your_password

JWT_SECRET=replace_with_a_secure_random_secret
CLIENT_ORIGIN=http://localhost:8081
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Firebase push notifications (set either path or inline JSON)
FIREBASE_SERVICE_ACCOUNT_PATH=C:\\path\\to\\trimride-firebase-adminsdk.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Firebase managed authentication
FIREBASE_AUTH_ENABLED=false
FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# Optional: investor demo lock mode (restricts dispatch/booking to specific accounts)
DEMO_LOCK_CUSTOMER_EMAIL=
DEMO_LOCK_BARBER_EMAIL=
